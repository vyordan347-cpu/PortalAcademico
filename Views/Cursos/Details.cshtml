@model PortalAcademico.Models.Curso

@{
    ViewData["Title"] = "Detalle del Curso";
}

<h1 class="mb-4">Detalle del Curso</h1>

<div class="card">
    <div class="card-body">
        <h4 class="card-title">@Model.Nombre</h4>
        <hr />

        <dl class="row">
            <dt class="col-sm-3">Código</dt>
            <dd class="col-sm-9">@Model.Codigo</dd>

            <dt class="col-sm-3">Créditos</dt>
            <dd class="col-sm-9">@Model.Creditos</dd>

            <dt class="col-sm-3">Cupo Máximo</dt>
            <dd class="col-sm-9">@Model.CupoMaximo</dd>

            <dt class="col-sm-3">Horario</dt>
            <dd class="col-sm-9">
                @Model.HorarioInicio.ToString("HH:mm") - @Model.HorarioFin.ToString("HH:mm")
            </dd>

            <dt class="col-sm-3">Activo</dt>
            <dd class="col-sm-9">@(Model.Activo ? "Sí" : "No")</dd>
        </dl>

        <div class="mt-3">
            <a href="#" class="btn btn-success">Inscribirse</a>
            <a asp-action="Index" class="btn btn-secondary">Volver al catálogo</a>
        </div>
    </div>
</div>