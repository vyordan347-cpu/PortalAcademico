@model PortalAcademico.Models.Curso

@{
    ViewData["Title"] = "Detalle del Curso";
}

<h1 class="mb-4">Detalle del Curso</h1>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<div class="card">
    <div class="card-body">
        <h4 class="card-title">@Model.Nombre</h4>
        <hr />

        <dl class="row">
            <dt class="col-sm-3">Código</dt>
            <dd class="col-sm-9">@Model.Codigo</dd>

            <dt class="col-sm-3">Créditos</dt>
            <dd class="col-sm-9">@Model.Creditos</dd>

            <dt class="col-sm-3">Cupo Máximo</dt>
            <dd class="col-sm-9">@Model.CupoMaximo</dd>

            <dt class="col-sm-3">Horario</dt>
            <dd class="col-sm-9">
                @Model.HorarioInicio.ToString("HH:mm") - @Model.HorarioFin.ToString("HH:mm")
            </dd>

            <dt class="col-sm-3">Activo</dt>
            <dd class="col-sm-9">@(Model.Activo ? "Sí" : "No")</dd>
        </dl>

        <div class="mt-3">
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <form asp-controller="Cursos" asp-action="Inscribirse" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-success">Inscribirse</button>
                </form>
            }
            else
            {
                <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-warning">
                    Inicia sesión para inscribirte
                </a>
            }

            <a asp-action="Index" class="btn btn-secondary">Volver al catálogo</a>
        </div>
    </div>
</div>